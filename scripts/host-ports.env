# Host-published port defaults for the dev machine (sourced by scripts/compose.sh).
# Prefix by stage: dev=85**, test=86**, live=87** (last two digits mirror the canonical port).
#
# Override any value in .env, or set VELLUM_STAGE=dev|test|live to pick a block.

VELLUM_STAGE="${VELLUM_STAGE:-dev}"

case "$VELLUM_STAGE" in
  dev) _hp=85 ;;
  test) _hp=86 ;;
  live) _hp=87 ;;
  *)
    echo "Error: VELLUM_STAGE must be dev, test, or live (got: $VELLUM_STAGE)" >&2
    exit 1
    ;;
esac

export VELLUM_PUBLIC_PORT="${VELLUM_PUBLIC_PORT:-${_hp}80}"
export APP_HOST_PORT="${APP_HOST_PORT:-${_hp}73}"
export WEB_HOST_PORT="${WEB_HOST_PORT:-${_hp}74}"
export POSTGRES_HOST_PORT="${POSTGRES_HOST_PORT:-${_hp}32}"
export REDIS_HOST_PORT="${REDIS_HOST_PORT:-${_hp}79}"
export MINIO_HOST_PORT="${MINIO_HOST_PORT:-${_hp}00}"
export MINIO_CONSOLE_HOST_PORT="${MINIO_CONSOLE_HOST_PORT:-${_hp}01}"
export MAILPIT_UI_HOST_PORT="${MAILPIT_UI_HOST_PORT:-${_hp}25}"
export MAILPIT_SMTP_HOST_PORT="${MAILPIT_SMTP_HOST_PORT:-${_hp}10}"
export PRISMA_STUDIO_PORT="${PRISMA_STUDIO_PORT:-${_hp}55}"
export DB_ADMIN_PORT="${DB_ADMIN_PORT:-${_hp}81}"
export SFTP_PORT="${SFTP_PORT:-${_hp}22}"
export WEBHOOK_HOST_PORT="${WEBHOOK_HOST_PORT:-${_hp}90}"
