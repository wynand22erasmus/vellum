generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

/// Dashboard user role for access control.
enum UserKind {
  ADMIN
  CONSUMER
}

/// Audit trail event types for compliance and security monitoring.
enum AuditEventType {
  USER_LOGIN
  EMAIL_INITIAL_SENT
  EMAIL_REGENERATE_SENT
  FILE_DOWNLOAD_SUCCESS
  FILE_DOWNLOAD_FAILED
  FILE_PURGED
  LINK_REVOKED
  CAPTCHA_FAILED
  RECIPIENT_OTP_SENT
  RECIPIENT_OTP_RESENT
  RECIPIENT_OTP_FAILED
  RECIPIENT_OTP_VERIFIED
  SFTP_FILE_RECEIVED
  SFTP_METADATA_VALIDATED
  SFTP_VIRUS_SCAN_PASSED
  SFTP_DOCUMENT_CREATED
  SFTP_STORAGE_UPLOADED
  SFTP_EMAIL_QUEUED
  SFTP_INGESTION_COMPLETED
  SFTP_INGESTION_FAILED
}

/// Queue pipeline that produced a dead-letter row.
enum DeadLetterPipeline {
  AUDIT
  PROCESS_ERROR
  WEBHOOK
}

/// Recipient OTP delivery channel configured per recipient identity.
enum RecipientOtpChannel {
  EMAIL
  SMS
  WHATSAPP
  AUTHENTICATOR
}

/// Local copy of dashboard users (WorkOS or dev login).
model User {
  userId            String   @id
  email             String   @unique
  emailVerified     Boolean  @default(false)
  kind              UserKind @default(CONSUMER)
  firstName         String?
  lastName          String?
  profilePictureUrl String?
  lastSignInAt      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Shared file asset stored once in S3 (deduplicated by sha256).
model File {
  fileId          String    @id @default(uuid())
  sha256          String    @unique
  s3Key           String?
  fileName        String
  fileExpiresAt   DateTime
  recordExpiresAt DateTime
  deletedAt       DateTime?
  byteSize        Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  documents Document[]
}

/// Logical recipient identity (source-system key + delivery contact + OTP prefs).
model Recipient {
  recipientId            String               @id @default(uuid())
  sourceSystemKey        String               @unique
  email                  String
  phoneNumber            String?
  otpChannel             RecipientOtpChannel?
  authenticatorSecretEnc String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  documents Document[]

  @@index([email])
}

/// Delivery envelope: file + recipient + password + download consumption.
model Document {
  documentId         String    @id @default(uuid())
  fileId             String
  file               File      @relation(fields: [fileId], references: [fileId], onDelete: Restrict)
  recipientId        String
  recipient          Recipient @relation(fields: [recipientId], references: [recipientId], onDelete: Restrict)
  passwordHash       String
  maxDownloads       Int       @default(1)
  downloadCount      Int       @default(0)
  verifySuccessCount Int       @default(0)
  lastVerifiedAt     DateTime?
  batchId            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  communications Communication[]
  auditLogs      AuditLog[]

  @@index([fileId, recipientId])
  @@index([batchId])
}

/// Outbound communication record (verify URL token + link expiry).
model Communication {
  communicationId String    @id @default(uuid())
  documentId      String
  document        Document  @relation(fields: [documentId], references: [documentId], onDelete: Restrict)
  downloadToken   String    @unique
  linkExpiresAt   DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditLogs AuditLog[]

  @@index([documentId])
}

/// Immutable audit events tied to documents, communications, and users.
model AuditLog {
  auditLogId      String         @id @default(uuid())
  eventType       AuditEventType
  createdAt       DateTime       @default(now())
  userId          String?
  documentId      String?
  document        Document?      @relation(fields: [documentId], references: [documentId], onDelete: Restrict)
  communicationId String?
  communication   Communication? @relation(fields: [communicationId], references: [communicationId], onDelete: Restrict)
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  processErrorId  String?
  expiresAt       DateTime

  @@index([processErrorId])
  @@index([documentId])
  @@index([communicationId])
  @@index([createdAt])
}

/// Dead-letter store when async queue processing fails.
model DeadLetter {
  deadLetterId String             @id @default(uuid())
  pipeline     DeadLetterPipeline
  payload      Json
  error        String
  retried      Boolean            @default(false)
  linkedTable  String?
  linkedId     String?
  createdAt    DateTime           @default(now())

  @@index([pipeline])
  @@index([pipeline, createdAt])
  @@index([retried])
  @@index([linkedTable, linkedId])
}

/// Operational failures recorded via the RFC 9457 error pipeline.
model ProcessError {
  processErrorId    String    @id @default(uuid())
  problemType       String
  title             String
  status            Int
  detail            String
  instance          String?
  requestId         String?
  source            String
  userId            String?
  documentId        String?
  communicationId   String?
  deadLetterId      String?
  extensions        Json?
  internal          Json?
  reconciledAt      DateTime?
  reconcileAttempts Int       @default(0)
  createdAt         DateTime  @default(now())
  auditLogId        String?
  correlationId     String?

  @@index([deadLetterId])
  @@index([auditLogId])
  @@index([correlationId])
  @@index([documentId])
  @@index([communicationId])
}

/// Outbound webhook delivery attempt (one row per HTTP try).
model WebhookDelivery {
  webhookDeliveryId String         @id @default(uuid())
  deliveryId        String         @unique
  auditLogId        String
  eventType         AuditEventType
  targetUrl         String
  payload           Json
  responseStatus    Int?
  responseBody      String?
  success           Boolean
  attempt           Int
  createdAt         DateTime       @default(now())

  @@index([auditLogId])
  @@index([eventType])
  @@index([createdAt])
}
