meta {
  name: Audit Logs CSV Export
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/admin/audit-logs?format=csv&limit=10
  body: none
  auth: none
}

headers {
  Accept: text/csv
  Cookie: {{adminSessionCookie}}
}

tests {
  test("should return csv", function() {
    expect(res.status).to.equal(200);
    expect(res.headers['content-type']).to.include('text/csv');
    expect(res.body).to.include('eventType');
  });
}
