{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Vellum API",
  "entryPoints": ["src", "e2e/helpers.ts"],
  "entryPointStrategy": "expand",
  "out": "docs/api/html",
  "tsconfig": "tsconfig.typedoc.json",
  "exclude": ["**/*.test.ts"],
  "excludeInternal": true,
  "readme": "README.md",
  "customCss": "docs/typedoc/typedoc-vellum.css",
  "customJs": "docs/typedoc/typedoc-vellum.js",
  "navigation": {
    "includeFolders": true
  }
}
