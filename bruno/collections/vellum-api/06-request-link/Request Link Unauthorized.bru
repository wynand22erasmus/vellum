meta {
  name: Request Link Unauthorized
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/documents/{{documentId}}/request-link
  body: none
  auth: none
}

tests {
  test("requires authentication", function () {
    expect(res.getStatus()).to.equal(401);
    expect(res.getHeader("content-type")).to.contain("application/problem+json");
    expect(res.getBody().type).to.be.a("string");
    expect(res.getBody().detail).to.contain("Not authenticated");
  });
}
