meta {
  name: List Documents
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/documents
  body: none
  auth: none
}

headers {
  X-Dev-User-Email: {{devEmail}}
}

tests {
  test("lists documents for recipient", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getHeader("content-type")).to.contain("application/vnd.vellum.result+json");
    const body = res.getBody();
    expect(body.data.Document).to.be.an("array");
    const match = body.data.Document.find((d) => d.fileName === bru.getEnvVar("fileName"));
    expect(match, "seeded document should appear in list").to.exist;
    expect(match.linkActive).to.equal(true);
    expect(match.fileAvailable).to.equal(true);
  });
}
