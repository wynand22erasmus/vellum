meta {
  name: Vellum API
}

auth {
  mode: none
}

docs {
  Vellum API collection. Pick an environment (Local, Remote, or Seeded) before running requests.

  - Local — localhost dev server defaults
  - Remote — point `baseUrl` and `apiKey` at another host (or override via CLI `--env-var`)
  - Seeded — generated by `npm run test:e2e:seed` after a document is created

  Open this workspace in Bruno via `bruno/workspace.yml`, or run CLI from this directory.
}
