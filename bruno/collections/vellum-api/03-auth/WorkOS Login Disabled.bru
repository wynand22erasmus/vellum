meta {
  name: WorkOS Login Disabled
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/auth/login
  body: none
  auth: none
}

tests {
  test("returns 400 when WorkOS is not enabled", function () {
    expect(res.getStatus()).to.equal(400);
    expect(res.getBody().error).to.contain("WorkOS");
  });
}
