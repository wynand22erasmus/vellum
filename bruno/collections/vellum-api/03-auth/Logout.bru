meta {
  name: Logout
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: none
}

tests {
  test("logout succeeds", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getHeader("content-type")).to.contain("application/vnd.vellum.result+json");
    const body = res.getBody();
    expect(body.detail).to.contain("Logged out");
  });
}
