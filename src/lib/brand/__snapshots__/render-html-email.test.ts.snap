// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderBrandedHtmlEmail > renders vellum download link HTML snapshot 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Your document is ready for collection.</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Secure document ready: contract.pdf</div>
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color:#f4f4f5;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:560px;background-color:#ffffff;border-radius:8px;border:1px solid #e5e7eb;">
          <tr>
            <td style="padding:32px 32px 24px;text-align:center;border-bottom:3px solid #2B6CB0;">
              <img src="https://vellum.example.com/brands/vellum/full.png" alt="Vellum" width="180" style="max-width:180px;height:auto;display:inline-block;" />
            </td>
          </tr>
          <tr>
            <td style="padding:32px;">
              <h1 style="margin:0 0 20px;font-size:22px;font-weight:600;line-height:1.3;color:#111827;">Your document is ready for collection.</h1>
              <p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#374151;">Visit the link below and enter your file password to download:</p>
<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#374151;">This link will expire as scheduled. Do not share this link.</p>
<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#374151;">If your download did not start, please log in to your Vellum dashboard to request a new link.</p>
              
              <table role="presentation" cellspacing="0" cellpadding="0" style="margin:24px 0;">
  <tr>
    <td style="border-radius:6px;background:#2B6CB0;">
      <a href="https://vellum.example.com/verify/token-abc" target="_blank" rel="noopener noreferrer"
         style="display:inline-block;padding:12px 24px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:6px;">
        Download document
      </a>
    </td>
  </tr>
</table>
<p style="margin:0 0 16px;font-size:13px;line-height:1.5;color:#6b7280;word-break:break-all;">
  https://vellum.example.com/verify/token-abc
</p>
              
            </td>
          </tr>
          <tr>
            <td style="padding:20px 32px 28px;border-top:1px solid #e5e7eb;text-align:center;font-size:12px;line-height:1.6;color:#9ca3af;">
              &copy; 2026 Vellum &middot; <a href="https://vellum.app/terms" style="color:inherit;">Terms</a> &middot; <a href="https://vellum.app/privacy" style="color:inherit;">Privacy</a><br/>Questions? Contact <a href="mailto:support@vellum.app" style="color:inherit;">support@vellum.app</a>
            </td>
          </tr>
        </table>
        <p style="margin:16px 0 0;font-size:11px;color:#9ca3af;">Sent by Vellum</p>
      </td>
    </tr>
  </table>
</body>
</html>"
`;
