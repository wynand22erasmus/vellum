meta {
  name: Auth Me Dev
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: none
}

headers {
  X-Dev-User-Email: {{devEmail}}
}

tests {
  test("returns dev user profile", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getHeader("content-type")).to.contain("application/vnd.vellum.result+json");
    const body = res.getBody();
    expect(body.data.provider).to.equal("dev");
    expect(body.data.user.email).to.match(/@example\.com$/);
  });
}
