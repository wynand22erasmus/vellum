# For Docker/Podman Compose, use .env.docker.example instead (service hostnames differ).
#
# Container image tagging (Compose/Podman/Docker; see README.md)
VELLUM_PROJECT=vellum
VELLUM_ENV=development

# Host port stage on the dev machine: dev=85**, test=86**, live=87** (see scripts/host-ports.env)
VELLUM_STAGE=dev

# Application
NODE_ENV=development
# Public hostname (substitute your domain). APP_URL is optional and overrides the derived URL.
VELLUM_HOST=localhost
VELLUM_PUBLIC_SCHEME=http
VELLUM_PUBLIC_PORT=8580
# APP_URL=http://localhost:8580
PORT=8573
API_KEY=dev-api-key-change-in-production

# Host-published ports (defaults from VELLUM_STAGE; override individually if needed)
# APP_HOST_PORT=8573
# WEB_HOST_PORT=8574

# PostgreSQL
DATABASE_URL=postgresql://vellum:password@localhost:8532/vellum_db
# Optional: remote dev server hostname (see .env.docker.example)
# VELLUM_HOST=devman.wtfgang.win

# Redis
REDIS_URL=redis://localhost:8579

# MinIO / S3
MINIO_ENDPOINT=http://localhost:8500
# Optional; presigned downloads use MINIO_ENDPOINT when unset
# MINIO_PUBLIC_ENDPOINT=http://localhost:8500
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=vellum-documents
AWS_REGION=us-east-1

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# WorkOS (Phase 9)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# WORKOS_REDIRECT_URI defaults to {APP_URL or derived URL}/api/auth/callback
AUTH_PROVIDER=dev

# JSON array of emails granted ADMIN on sign-in (see users table)
DEFAULT_ADMIN_EMAILS=["wynand22erasmus@gmail.com"]

# Session
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Email
EMAIL_PROVIDER=local
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

# AWS SES (Production)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Lifecycle Configuration
REPORTING_LIFETIME_YEARS=5

# E2E / local testing only (ignored when NODE_ENV=production)
SKIP_VIRUS_SCAN=false
# SKIP_EMAIL_VERIFICATION=true
# SKIP_CAPTCHA=true
# RECIPIENT_OTP_DEV_CODE=123456

# hCaptcha (item 10)
CAPTCHA_PROVIDER=off
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=

# Recipient OTP (item 5)
RECIPIENT_OTP_ENABLED=false
# OTP_TTL_SECONDS=600
# OTP_MAX_ATTEMPTS=5
# OTP_MAX_RESENDS=3
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TOTP_ENCRYPTION_KEY=
# Not read by the app — upload TTLs are per-request (linkTtl, fileTtl on POST /api/upload)
# DEFAULT_LINK_TTL_SECONDS=86400
# MAX_FILE_RETENTION_DAYS=90
MAX_UPLOAD_BYTES=52428800
MAX_BATCH_RECIPIENTS=50
# SFTP ingestion (Compose: see .env.docker.example; host-only: set SFTP_ENABLED=true and mount inbox path)
# SFTP_ENABLED=false
# SFTP_INBOX_PATH=/sftp
# SFTP_ARCHIVE_PATH=/sftp/archive
# SFTP_FAILED_PATH=/sftp/failed
# SFTP_MANIFEST_SUFFIX=.json
# Allowed upload extensions (JSON array, lowercase, no dots). Omit for defaults (pdf, txt, docx, …). Use ["*"] for any type; .exe and similar trailing spoof extensions are always stripped from filenames.
# ALLOWED_UPLOAD_EXTENSIONS=["pdf","docx","txt"]

# DB UI ports (postgres container when using Compose)
PRISMA_STUDIO_PORT=8555
DB_ADMIN_PORT=8581

# White-label branding (must match between SPA and server)
# VITE_BRAND_PRESET=vellum
# BRAND_PRESET=vellum
# BRAND_LOGO_URL=https://your-cdn.example.com/logo.png
# BRAND_PRIMARY_COLOR=#2B6CB0
# BRAND_FOOTER_HTML=© 2026 Your Co · <a href="https://example.com/terms">Terms</a>
# BRAND_SUPPORT_EMAIL=support@example.com
# See .env.brand.vellum and .env.brand.client-example for per-client Vite modes.
