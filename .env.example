# For Docker/Podman Compose, use .env.docker.example instead (service hostnames differ).
#
# Application
NODE_ENV=development
APP_URL=http://localhost:5173
PORT=3000
API_KEY=dev-api-key-change-in-production

# PostgreSQL
DATABASE_URL=postgresql://vellum:password@localhost:5432/vellum_db

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=vellum-documents
AWS_REGION=us-east-1

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# WorkOS (Phase 9)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:5173/api/auth/callback
AUTH_PROVIDER=dev

# Session
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Email
EMAIL_PROVIDER=local
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

# AWS SES (Production)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Lifecycle Configuration
REPORTING_LIFETIME_YEARS=5

# E2E / local testing only (ignored when NODE_ENV=production)
SKIP_VIRUS_SCAN=false
DEFAULT_LINK_TTL_SECONDS=86400
MAX_FILE_RETENTION_DAYS=90
MAX_UPLOAD_BYTES=52428800
