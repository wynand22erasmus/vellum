{
  "name": "vellum",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.14.1",
  "overrides": {
    "axios": "^1.16.1"
  },
  "scripts": {
    "dev": "vite",
    "dev:brand": "vite --mode brand.vellum",
    "dev:brand:client-example": "vite --mode brand.client-example",
    "build:brand:vellum": "tsc -b && vite build --mode brand.vellum",
    "build:brand:client-example": "tsc -b && vite build --mode brand.client-example",
    "dev:stack": "node scripts/dev-stack.mjs",
    "dev:api": "tsx src/api-server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check:error-patterns": "node scripts/check-error-patterns.mjs",
    "preview": "vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "bash scripts/db-studio.sh",
    "db:studio:logs": "bash scripts/compose.sh logs -f postgres",
    "worker": "tsx src/server/workers/index.ts",
    "compose": "bash scripts/compose.sh",
    "up": "bash scripts/compose.sh up -d --build",
    "up:logs": "bash scripts/compose.sh logs -f app worker",
    "down": "bash scripts/compose.sh down",
    "infra:up": "bash scripts/compose.sh up -d postgres redis minio clamav mailpit",
    "infra:down": "bash scripts/compose.sh down",
    "infra:logs": "bash scripts/compose.sh logs -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:prepare": "node scripts/e2e-prepare-browser.mjs",
    "test:e2e:seed": "PUPPETEER_CACHE_DIR=.cache/puppeteer E2E_BASE_URL=http://localhost:5174 node --import tsx scripts/e2e-seed.mjs",
    "test:api": "PUPPETEER_CACHE_DIR=.cache/puppeteer E2E_BASE_URL=http://localhost:5174 node scripts/e2e-seed.mjs && cd bruno/collections/vellum-api && bru run 01-health 02-upload 03-auth 04-documents 05-verify 06-request-link --env Seeded",
    "test:api:smoke": "cd bruno/collections/vellum-api && bru run 01-health 02-upload 03-auth 05-verify --env Local",
    "test:api:remote": "cd bruno/collections/vellum-api && bru run 01-health 02-upload 03-auth 04-documents 05-verify 06-request-link --env Remote",
    "test:e2e": "PUPPETEER_CACHE_DIR=.cache/puppeteer E2E_BASE_URL=http://localhost:5174 node scripts/e2e-seed.mjs && PUPPETEER_CACHE_DIR=.cache/puppeteer E2E_BASE_URL=http://localhost:5174 node --import tsx --test e2e/tests/*.test.ts",
    "test:e2e:smoke": "PUPPETEER_CACHE_DIR=.cache/puppeteer node --import tsx --test e2e/tests/home.test.ts e2e/tests/theme-branding.test.ts e2e/tests/health.test.ts",
    "test:e2e:all": "npm run test:api && npm run test:e2e",
    "brand:images": "node scripts/process-brand-images.mjs",
    "docs:api": "typedoc && typedoc --options typedoc.markdown.json",
    "docs:api:html": "typedoc",
    "docs:api:markdown": "typedoc --options typedoc.markdown.json",
    "docs:coverage": "node scripts/doc-coverage.mjs",
    "docs:inventory": "node scripts/doc-inventory.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-ses": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/studio-core": "^0.9.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-table": "^8.21.3",
    "@workos-inc/node": "^9.3.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.14",
    "@types/babel__core": "^7.20.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@usebruno/cli": "^3.4.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prisma": "^7.8.0",
    "puppeteer": "^24.0.0",
    "shadcn": "^4.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
