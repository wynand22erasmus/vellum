# Copy to .env when running the full stack in containers:
#   cp .env.docker.example .env

# Container image tagging (Compose/Podman/Docker; see README.md)
VELLUM_PROJECT=vellum
VELLUM_ENV=development

# Host port stage on the dev machine: dev=85**, test=86**, live=87** (see scripts/host-ports.env)
VELLUM_STAGE=dev

# Application
NODE_ENV=development
# Public hostname (substitute your domain). APP_URL is optional and overrides the derived URL.
VELLUM_HOST=devman.wtfgang.win
VELLUM_PUBLIC_SCHEME=http
VELLUM_PUBLIC_PORT=8580
# APP_URL=http://devman.wtfgang.win:8580
PORT=3000
API_KEY=dev-api-key-change-in-production

# Host-published ports (defaults from VELLUM_STAGE; override individually if needed)
# APP_HOST_PORT=8573
# WEB_HOST_PORT=8574

# PostgreSQL (compose service name)
DATABASE_URL=postgresql://vellum:password@postgres:5432/vellum_db
# Host-side tools (npm run db:studio without Compose): connect via published port
DATABASE_URL_HOST=postgresql://vellum:password@localhost:8532/vellum_db

# Redis
REDIS_URL=redis://redis:6379

# MinIO / S3
MINIO_ENDPOINT=http://minio:9000
# Presigned download URLs for browsers (defaults to http://$VELLUM_HOST:$MINIO_HOST_PORT when unset)
MINIO_PUBLIC_ENDPOINT=http://devman.wtfgang.win:8500
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=vellum-documents
AWS_REGION=us-east-1

# ClamAV
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# WorkOS
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# WORKOS_REDIRECT_URI defaults to {APP_URL or derived URL}/api/auth/callback
AUTH_PROVIDER=dev

# JSON array of emails granted ADMIN on sign-in (see users table)
DEFAULT_ADMIN_EMAILS=["wynand22erasmus@gmail.com"]

# Session
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Email (Mailpit service)
EMAIL_PROVIDER=local
MAILPIT_HOST=mailpit
MAILPIT_PORT=1025

# AWS SES (Production)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Lifecycle Configuration
REPORTING_LIFETIME_YEARS=5
# Not read by the app — upload TTLs are per-request (linkTtl, fileTtl on POST /api/upload)
# DEFAULT_LINK_TTL_SECONDS=86400
# MAX_FILE_RETENTION_DAYS=90
MAX_UPLOAD_BYTES=52428800
# Download limits and verify re-verify window (roadmap items 1 & 4)
DEFAULT_MAX_DOWNLOADS=1
REVERIFY_WINDOW_MS=300000
MAX_REVERIFY_ATTEMPTS=3
# Admin audit export page size cap (roadmap item 3)
AUDIT_EXPORT_MAX_LIMIT=500
# Allowed upload extensions — see .env.example
# ALLOWED_UPLOAD_EXTENSIONS=["pdf","txt"]

# DB UIs in postgres container (Prisma Studio + Adminer; Development sidebar)
PRISMA_STUDIO_PORT=8555
# MinIO console subpath for dev UI embed via host nginx (defaults in compose if unset)
# MINIO_BROWSER_REDIRECT_URL=http://devman.wtfgang.win:8580/dev-proxy/minio-console/
DB_ADMIN_PORT=8581

# E2E / local testing — set true to skip ClamAV scans (never use in production)
SKIP_VIRUS_SCAN=true
# E2E only — bypass email verification for automated tests (never use in production)
SKIP_EMAIL_VERIFICATION=true
# E2E only — skip hCaptcha on verify (never use in production)
SKIP_CAPTCHA=true
# E2E/dev fixed OTP when testing RECIPIENT_OTP_ENABLED=true
# RECIPIENT_OTP_DEV_CODE=123456

# hCaptcha (item 10) — off by default; set hcaptcha to enable
CAPTCHA_PROVIDER=off
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=

# Recipient OTP (item 5) — off by default
RECIPIENT_OTP_ENABLED=false
# OTP_TTL_SECONDS=600
# OTP_MAX_ATTEMPTS=5
# OTP_MAX_RESENDS=3
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TOTP_ENCRYPTION_KEY=

# Outbound webhooks (item 11) — off by default; webhook-tester UI at http://$VELLUM_HOST:8590
WEBHOOKS_ENABLED=false
# WEBHOOK_SECRET=dev-webhook-secret-change-me
# WEBHOOK_MAX_RETRIES=5
# Point each URL at a webhook-tester session path (auto-created when --auto-create-sessions is set):
# WEBHOOK_URL_FILE_DOWNLOAD_SUCCESS=http://webhook-tester:8080/vellum-file-download-success
# WEBHOOK_URL_USER_LOGIN=http://webhook-tester:8080/vellum-user-login
# WEBHOOK_URL_FILE_DOWNLOAD_FAILED=http://webhook-tester:8080/vellum-file-download-failed

# SFTP ingestion (item 9) — enabled in Compose worker by default
# SFTP_ENABLED=true
# SFTP_PORT=8522
# SFTP_PASSWORD=devpassword
# SFTP_USER=partner
# SFTP_INBOX_PATH=/sftp
# SFTP_ARCHIVE_PATH=/sftp/archive
# SFTP_FAILED_PATH=/sftp/failed
# SFTP_MANIFEST_SUFFIX=.json

# White-label HTML emails (optional overrides; defaults from brand preset)
# BRAND_LOGO_URL=
# BRAND_PRIMARY_COLOR=
# BRAND_FOOTER_HTML=
# BRAND_SUPPORT_EMAIL=
