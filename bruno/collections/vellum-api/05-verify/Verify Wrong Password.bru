meta {
  name: Verify Wrong Password
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/verify
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "token": "{{downloadToken}}",
    "password": "wrong-password-xyz"
  }
}

tests {
  test("rejects incorrect password", function () {
    expect(res.getStatus()).to.equal(401);
    expect(res.getBody().error).to.contain("password");
  });
}
