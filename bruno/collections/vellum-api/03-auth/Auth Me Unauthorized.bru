meta {
  name: Auth Me Unauthorized
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: none
}

tests {
  test("returns null user when not authenticated", function () {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.user).to.equal(null);
    expect(body.provider).to.be.a("string");
  });
}
